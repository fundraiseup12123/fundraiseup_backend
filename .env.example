STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
FRONTEND_URL=http://localhost:3000
# Custom domain for admin + campaign subdomains (production: https://fundraiseup.us.com)
PLATFORM_ROOT_DOMAIN=
CUSTOM_DOMAIN_CNAME_TARGET=
ROOT_CAMPAIGN_SUBDOMAIN=sudan-needs-you
STRIPE_CONNECT_CLIENT_ID=ca_...
# Set to true only if Standard OAuth is enabled in Stripe Connect settings
STRIPE_CONNECT_USE_STANDARD_OAUTH=false
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform PayPal app (developer.paypal.com) — one-time server setup, not per admin
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=GBP
PAYPAL_BN_CODE=
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=FundraiseUp <donations@yourdomain.com>
# Donor portal magic-link signing (falls back to SUPABASE_JWT_SECRET / SUPABASE_SECRET_KEY)
DONOR_PORTAL_SECRET=
# When true (or Resend is unset), magic-link API also returns debug_link for local testing
DONOR_PORTAL_DEBUG=false
# Max Resend API sends per second (default 2). Excess emails wait in queue.
RESEND_MAX_PER_SECOND=2
EMAIL_LOGO_URL=
EMAIL_BANNER_URL=
CRON_SECRET=your-random-cron-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google Analytics 4 (admin portal reports — Data API)
# Numeric property ID from GA4 Admin → Property settings (not the G- measurement ID)
GA4_PROPERTY_ID=
# Service account JSON string OR path to JSON file (Viewer access on the GA4 property)
GA4_SERVICE_ACCOUNT_JSON=
GA4_SERVICE_ACCOUNT_FILE=

# NOWPayments (crypto) — optional; org keys are stored per account in admin UI
NOWPAYMENTS_ENV=live
NOWPAYMENTS_API_BASE=
# Public API base for IPN callbacks (defaults to FRONTEND_URL/api/backend)
PUBLIC_API_URL=
